{
  "name": "pi-desktop",
  "version": "0.2.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/copy-assets.mjs && electron-vite dev",
    "build": "electron-vite build && node scripts/copy-assets.mjs",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "dist": "pnpm build && electron-builder --config.nsis.oneClick=false",
    "dist:win": "pnpm build && electron-builder --win --config.nsis.oneClick=false"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.6.0",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-image": "^3.28.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-table": "^3.28.0",
    "@tiptap/extension-task-item": "^3.28.0",
    "@tiptap/extension-task-list": "^3.28.0",
    "@tiptap/extension-underline": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.18.0",
    "mermaid": "^11.16.0",
    "monaco-editor": "^0.52.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tiptap-markdown": "~0.9.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.0",
    "png-to-ico": "^3.0.2",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "com.pi.desktop",
    "productName": "pi-desktop",
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "npmArgs": [],
    "extraResources": [
      {
        "from": "src/main/assets/tray-icon.png",
        "to": "assets/tray-icon.png",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/main/assets/tray-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/main/assets/tray-icon.ico",
      "uninstallerIcon": "src/main/assets/tray-icon.ico",
      "runAfterFinish": true
    },
    "mac": {
      "target": "dmg",
      "icon": "src/main/assets/tray-icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/main/assets/tray-icon.png",
      "category": "Development"
    },
    "directories": {
      "output": "release"
    }
  }
}